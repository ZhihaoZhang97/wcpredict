# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# --- LLM provider ---------------------------------------------------
# predict uses Claude by default; pick another provider with
# `predict --provider <name>` or by uncommenting these:
#WCPREDICT_LLM_PROVIDER=anthropic   # anthropic | openai | gemini | qwen | glm | kimi | minimax | deepseek
#WCPREDICT_LLM_MODEL=               # optional: override the provider's default model

# Set the key for the provider(s) you use:
ANTHROPIC_API_KEY=sk-ant-your-key-here
#OPENAI_API_KEY=          # https://platform.openai.com
#GOOGLE_API_KEY=          # Gemini — https://aistudio.google.com/apikey
#DASHSCOPE_API_KEY=       # Qwen — https://dashscope.console.aliyun.com
#ZHIPUAI_API_KEY=         # GLM — https://open.bigmodel.cn
#MOONSHOT_API_KEY=        # Kimi — https://platform.moonshot.ai
#MINIMAX_API_KEY=         # https://platform.minimax.io
#DEEPSEEK_API_KEY=        # https://platform.deepseek.com

# Player research web search — free tier at https://tavily.com
TAVILY_API_KEY=tvly-your-key-here
